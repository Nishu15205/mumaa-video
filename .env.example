# ─── Environment Variables ──────────────────────────
# Copy this file to .env and fill in the values

# Database (Render PostgreSQL will set this automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/mumaa

# Authentication
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=https://your-domain.onrender.com
JWT_SECRET=your-jwt-secret-here

# Socket.IO Server (Render will set NEXT_PUBLIC_SOCKET_URL automatically)
NEXT_PUBLIC_SOCKET_URL=https://your-socket-service.onrender.com

# TURN Server for WebRTC (REQUIRED for cross-network video calls)
# Without TURN, video calls only work on the same network
#
# Option 1: Self-hosted (recommended - deploy turn-service mini-service)
#   TURN_URL=turn:your-server-ip:3478,turn:your-server-ip:3478?transport=tcp
#   TURN_USERNAME=mumaa
#   TURN_CREDENTIAL=mumaa-turn-password
#
# Option 2: Free cloud TURN (Metered.ca Open Relay - rate limited)
#   No config needed — built-in fallback is used automatically
#
# Option 3: Paid cloud TURN (best reliability)
#   Twilio: https://www.twilio.com/docs/stun-turn
#   Xirsys: https://xirsys.com (free tier: 1GB/month)
#
# Server-side env vars (preferred - no rebuild needed):
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

# Stripe (optional - for payments)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email / SMTP (optional - for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Web Push Notifications (optional)
NEXT_PUBLIC_VAPID_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=
