# ─── Environment Variables ──────────────────────────
# Copy this file to .env and fill in the values

# Database (Render PostgreSQL will set this automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/mumaa

# Authentication
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=https://your-domain.onrender.com
JWT_SECRET=your-jwt-secret-here

# Socket.IO Server (Render will set NEXT_PUBLIC_SOCKET_URL automatically)
NEXT_PUBLIC_SOCKET_URL=https://your-socket-service.onrender.com

# TURN Server for WebRTC (optional but recommended for mobile)
# Free options: Metered.ca, Twilio, Xirsys
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=

# Stripe (optional - for payments)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email / SMTP (optional - for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Web Push Notifications (optional)
NEXT_PUBLIC_VAPID_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=
